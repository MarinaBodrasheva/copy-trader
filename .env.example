# Tradovate environment: "demo" or "live"
TRADOVATE_ENV=demo

# Tradovate API credentials (same for all accounts under one login)
TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password
TRADOVATE_APP_ID=Sample App
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=your_cid
TRADOVATE_SEC=your_sec

# Master account - Tradovate account name or ID
MASTER_ACCOUNT_ID=123456

# Slave accounts - comma-separated Tradovate account IDs
SLAVE_ACCOUNT_IDS=234567,345678,456789

# Telegram alerts (optional — leave blank to disable)
# Create a bot via @BotFather, then get your chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Daily loss guard — stops copying to a slave once limits are breached. Set to 0 to disable.
MAX_DAILY_LOSS_USD=500        # realized P&L only
MAX_TOTAL_DAILY_LOSS_USD=600  # realized + open (unrealized) combined — matches most prop firm rules

# Web dashboard port (default: 3000) — open http://localhost:3000 in your browser
WEB_PORT=3000
